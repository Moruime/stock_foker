# === LLM 配置 ===
# 是否启用 AI 分析功能 (true/false)
LLM_ENABLED=false

# LLM 提供商标记 (仅用于日志，不影响功能)
# 可选: deepseek, moonshot, zhipu, qwen, openai
LLM_PROVIDER=deepseek

# API Key (必须填写才能启用 AI 功能)
LLM_API_KEY=your-api-key-here

# API 基地址 (OpenAI 兼容接口)
# DeepSeek: https://api.deepseek.com/v1
# Moonshot: https://api.moonshot.cn/v1
# 智谱GLM: https://open.bigmodel.cn/api/paas/v4
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名称
# DeepSeek: deepseek-chat
# Moonshot: moonshot-v1-8k
# GLM: glm-4-flash
# Qwen: qwen-turbo
# OpenAI: gpt-4o-mini
LLM_MODEL=deepseek-chat

# 温度 (0-1, 越低越确定性)
LLM_TEMPERATURE=0.3

# 最大输出 token
LLM_MAX_TOKENS=2048

# 请求超时秒数
LLM_TIMEOUT=60

# 是否启用模型思考/推理模式 (true/false)
# Qwen3 等推理模型默认开启 thinking 模式，会先生成内部推理链再输出结果
# 关闭后可大幅降低响应延迟，适合结构化输出（JSON）场景
LLM_ENABLE_THINKING=false
